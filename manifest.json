{
  "manifest_version": 3,
  "name": "FreeMyGHL — GHL Site Exporter",
  "version": "3.0.0",
  "description": "Export, backup & deploy any GoHighLevel, Framer, Webflow, Lovable or AI-built site. GitHub, Netlify, Vercel, Cloudflare Pages — one click. Own your work forever.",
  "permissions": [
    "activeTab",
    "scripting",
    "downloads",
    "storage",
    "webNavigation",
    "alarms",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.gohighlevel.com/*", "*://*.leadconnectorhq.com/*", "*://*.vibepreview.com/*"],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": ["*://*.gohighlevel.com/*", "*://*.leadconnectorhq.com/*"],
      "js": ["shared-asset-collector.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["crawler.js", "shared-asset-collector.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
